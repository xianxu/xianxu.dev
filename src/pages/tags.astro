---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import { cleanSlug, getPermalink } from '~/utils/permalinks';

export const prerender = true;

const posts = (await getCollection('post')).filter((p) => !p.data.draft);

const counts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    const slug = cleanSlug(tag);
    counts.set(slug, (counts.get(slug) ?? 0) + 1);
  }
}

const tags = [...counts.entries()]
  .map(([slug, count]) => ({ slug, count }))
  .sort((a, b) => b.count - a.count || a.slug.localeCompare(b.slug));

const metadata = {
  title: 'Tags',
};
---

<Layout metadata={metadata}>
  <section class="px-4 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <h1 class="text-3xl md:text-4xl font-bold leading-tighter tracking-tighter font-heading mb-3">Tags</h1>
    <p class="text-muted dark:text-slate-400 mb-12">Browse posts by tag.</p>

    {tags.length === 0 ? (
      <p class="text-muted">No tags yet.</p>
    ) : (
      <ul class="text-sm">
        {tags.map(({ slug, count }) => (
          <li class="bg-gray-100 dark:bg-slate-700 inline-block mr-2 mb-2 py-0.5 px-2 lowercase font-medium">
            <a
              href={getPermalink(slug, 'tag')}
              class="text-muted dark:text-slate-300 hover:text-primary dark:hover:text-gray-200"
            >
              {slug}
              <span class="ml-1 opacity-60">({count})</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</Layout>
