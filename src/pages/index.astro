---
import Layout from '~/layouts/PageLayout.astro';
import List from '~/components/blog/List.astro';
import { findLatestPosts } from '~/utils/blog';
import { getBlogPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Xian Xu — personal blog',
  ignoreTitleTemplate: true,
};

const posts = await findLatestPosts({ count: 10 });
---

<Layout metadata={metadata}>
  <section class="px-4 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <h1 class="text-3xl md:text-4xl font-bold leading-tighter tracking-tighter font-heading mb-3">Latest posts</h1>
    <p class="text-muted dark:text-slate-400 mb-12">
      <a href={getBlogPermalink()} class="hover:text-primary dark:hover:text-blue-400">View all posts »</a>
    </p>
    <List posts={posts} />
    <div class="mt-12 text-center">
      <a href={`${getBlogPermalink()}/2`} class="text-primary dark:text-blue-400 hover:underline">
        Read more posts »
      </a>
    </div>
  </section>
</Layout>
