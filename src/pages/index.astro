---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import List from '~/components/blog/List.astro';
import { findLatestPosts } from '~/utils/blog';
import { cleanSlug, getBlogPermalink, getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Xian Xu — personal blog',
  ignoreTitleTemplate: true,
};

const posts = await findLatestPosts({ count: 10 });

// All tags across published posts, most-used first — a quick-filter row next to
// "View all posts »". Mirrors the collection logic in pages/tags.astro.
const counts = new Map<string, number>();
for (const post of await getCollection('post')) {
  if (post.data.published !== true) continue;
  for (const tag of post.data.tags ?? []) {
    const slug = cleanSlug(tag);
    counts.set(slug, (counts.get(slug) ?? 0) + 1);
  }
}
const tags = [...counts.entries()]
  .map(([slug, count]) => ({ slug, count }))
  .sort((a, b) => b.count - a.count || a.slug.localeCompare(b.slug));
---

<Layout metadata={metadata}>
  <section class="px-4 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <h1 class="text-3xl md:text-4xl font-bold leading-tighter tracking-tighter font-heading mb-3">Latest posts</h1>
    <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-muted dark:text-slate-400 mb-12">
      <a href={getBlogPermalink()} class="hover:text-primary dark:hover:text-blue-400">View all posts »</a>
      {tags.length > 0 && (
        <ul class="flex flex-wrap gap-2 text-sm">
          {tags.map(({ slug }) => (
            <li class="bg-gray-100 dark:bg-slate-700 py-0.5 px-2 lowercase font-medium">
              <a
                href={getPermalink(slug, 'tag')}
                class="text-muted dark:text-slate-300 hover:text-primary dark:hover:text-gray-200"
              >
                {slug}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
    <List posts={posts} />
    <div class="mt-12 text-center">
      <a href={`${getBlogPermalink()}/2`} class="text-primary dark:text-blue-400 hover:underline">
        Read more posts »
      </a>
    </div>
  </section>
</Layout>
