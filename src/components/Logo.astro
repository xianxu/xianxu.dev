---
import { SITE } from 'astrowind:config';
import favIcon from '~/assets/favicons/favicon.png';
---

<span
  class="self-center ml-2 rtl:ml-0 rtl:mr-2 text-2xl md:text-3xl font-bold text-gray-900 whitespace-nowrap dark:text-white tracking-tight inline-flex items-center gap-1"
  aria-label={`${SITE?.name} logo`}
>
  <span
    class="logo-symbol inline-flex items-center justify-center font-normal"
    style="width: 1.4em; height: 1.4em;"
    aria-hidden="true"
    data-favicon={favIcon.src}
  ><img src={favIcon.src} alt="" style="width:75%;height:75%;object-fit:contain;display:inline-block" /></span>
  <span class="tracking-tight">{SITE?.name}</span>
</span>

<script>
  // Each frame: [symbol, hold time in ms]. The token "FAVICON" swaps in the
  // site favicon as a frame. Story: thinking → idea (favicon) → writing.
  const FRAMES: [string, number][] = [
    ['?', 700],
    [':', 700],
    ['🤔', 800],
    ['⠋', 30], ['⠙', 30], ['⠹', 30], ['⠸', 30], ['⠼', 30],
    ['⠴', 30], ['⠦', 30], ['⠧', 30], ['⠇', 30], ['⠏', 30],
    ['⠋', 30], ['⠙', 30], ['⠹', 30], ['⠸', 30], ['⠼', 30],
    ['⠴', 30], ['⠦', 30], ['⠧', 30], ['⠇', 30], ['⠏', 30],
    ['FAVICON', 2000],
    ['⠏', 30], ['⠇', 30], ['⠧', 30], ['⠦', 30], ['⠴', 30],
    ['⠼', 30], ['⠸', 30], ['⠹', 30], ['⠙', 30], ['⠋', 30],
    ['⠏', 30], ['⠇', 30], ['⠧', 30], ['⠦', 30], ['⠴', 30],
    ['⠼', 30], ['⠸', 30], ['⠹', 30], ['⠙', 30], ['⠋', 30],
    ['✍️', 1500],
  ];

  // Animation only earns its keep at the top of the page. When the reader
  // scrolls down, run a short spinner transition then settle on the favicon.
  // When they scroll back up, play the spinner again, then loop the main story.
  const SCROLL_PAUSE_THRESHOLD = 50;
  const SPINNER = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏'];
  const SPINNER_DELAY = 30;
  const TRANSITION_FRAMES = [...SPINNER, ...SPINNER]; // two rounds

  type Mode = 'main' | 'pausing' | 'paused' | 'resuming';
  let mode: Mode = 'main';
  let mainIdx = 0;
  let transIdx = 0;
  let timer: number | null = null;

  const renderFrame = (symbol: string) => {
    document.querySelectorAll<HTMLElement>('.logo-symbol').forEach((el) => {
      if (symbol === 'FAVICON') {
        const src = el.dataset.favicon || '';
        el.innerHTML = `<img src="${src}" alt="" style="width:75%;height:75%;object-fit:contain;display:inline-block" />`;
      } else {
        el.textContent = symbol;
      }
    });
  };

  const tick = () => {
    if (mode === 'paused') return;

    if (mode === 'main') {
      const [symbol, delay] = FRAMES[mainIdx];
      renderFrame(symbol);
      mainIdx = (mainIdx + 1) % FRAMES.length;
      timer = window.setTimeout(tick, delay);
      return;
    }

    // 'pausing' or 'resuming' — both play through TRANSITION_FRAMES
    if (transIdx < TRANSITION_FRAMES.length) {
      renderFrame(TRANSITION_FRAMES[transIdx]);
      transIdx += 1;
      timer = window.setTimeout(tick, SPINNER_DELAY);
      return;
    }

    // Transition complete
    if (mode === 'pausing') {
      mode = 'paused';
      renderFrame('FAVICON');
    } else {
      // resuming
      mode = 'main';
      mainIdx = 0;
      tick();
    }
  };

  const updatePause = () => {
    const shouldPause = window.scrollY > SCROLL_PAUSE_THRESHOLD;
    if (shouldPause && (mode === 'main' || mode === 'resuming')) {
      if (timer !== null) clearTimeout(timer);
      mode = 'pausing';
      transIdx = 0;
      tick();
    } else if (!shouldPause && (mode === 'paused' || mode === 'pausing')) {
      if (timer !== null) clearTimeout(timer);
      mode = 'resuming';
      transIdx = 0;
      tick();
    }
  };

  window.addEventListener('scroll', updatePause, { passive: true });
  tick();
</script>
