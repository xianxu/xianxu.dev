---
import { SITE } from 'astrowind:config';
import favIcon from '~/assets/favicons/favicon.png';
---

<span
  class="self-center ml-2 rtl:ml-0 rtl:mr-2 text-2xl md:text-3xl font-bold text-gray-900 whitespace-nowrap dark:text-white tracking-tight inline-flex items-center gap-1"
  aria-label={`${SITE?.name} logo`}
>
  <span
    class="logo-symbol inline-flex items-center justify-center font-normal"
    style="width: 1.4em; height: 1.4em;"
    aria-hidden="true"
    data-favicon={favIcon.src}
  ><img src={favIcon.src} alt="" style="width:75%;height:75%;object-fit:contain;display:inline-block" /></span>
  <span class="tracking-tight">{SITE?.name}</span>
</span>

<script>
  // Animation runs only on the home page. Re-evaluated on every astro:page-load
  // because the site uses ClientRouter (SPA navigation), so scripts don't re-run
  // on plain navigation.
  type Mode = 'main' | 'pausing' | 'paused' | 'resuming';

  type LogoState = {
    timer: number | null;
    scrollHandler: (() => void) | null;
  };

  // Single shared state stashed on window so successive page-load handlers
  // can clean up whatever the previous page started.
  const w = window as unknown as { __logoState?: LogoState };

  const FRAMES: [string, number][] = [
    ['?', 700],
    [':', 700],
    ['🤔', 800],
    ['⠋', 30], ['⠙', 30], ['⠹', 30], ['⠸', 30], ['⠼', 30],
    ['⠴', 30], ['⠦', 30], ['⠧', 30], ['⠇', 30], ['⠏', 30],
    ['⠋', 30], ['⠙', 30], ['⠹', 30], ['⠸', 30], ['⠼', 30],
    ['⠴', 30], ['⠦', 30], ['⠧', 30], ['⠇', 30], ['⠏', 30],
    ['FAVICON', 2000],
    ['⠏', 30], ['⠇', 30], ['⠧', 30], ['⠦', 30], ['⠴', 30],
    ['⠼', 30], ['⠸', 30], ['⠹', 30], ['⠙', 30], ['⠋', 30],
    ['⠏', 30], ['⠇', 30], ['⠧', 30], ['⠦', 30], ['⠴', 30],
    ['⠼', 30], ['⠸', 30], ['⠹', 30], ['⠙', 30], ['⠋', 30],
    ['✍️', 1500],
  ];
  const SCROLL_PAUSE_THRESHOLD = 50;
  const SPINNER = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏'];
  const SPINNER_DELAY = 30;
  const TRANSITION_FRAMES = [...SPINNER, ...SPINNER];

  const renderFrame = (symbol: string) => {
    document.querySelectorAll<HTMLElement>('.logo-symbol').forEach((el) => {
      if (symbol === 'FAVICON') {
        const src = el.dataset.favicon || '';
        el.innerHTML = `<img src="${src}" alt="" style="width:75%;height:75%;object-fit:contain;display:inline-block" />`;
      } else {
        el.textContent = symbol;
      }
    });
  };

  const teardown = () => {
    const state = w.__logoState;
    if (!state) return;
    if (state.timer !== null) {
      clearTimeout(state.timer);
      state.timer = null;
    }
    if (state.scrollHandler) {
      window.removeEventListener('scroll', state.scrollHandler);
      state.scrollHandler = null;
    }
  };

  const setup = () => {
    teardown();
    if (window.location.pathname !== '/') {
      renderFrame('FAVICON');
      return;
    }

    const state: LogoState = { timer: null, scrollHandler: null };
    w.__logoState = state;

    let mode: Mode = 'main';
    let mainIdx = 0;
    let transIdx = 0;

    const tick = () => {
      if (mode === 'paused') return;

      if (mode === 'main') {
        const [symbol, delay] = FRAMES[mainIdx];
        renderFrame(symbol);
        mainIdx = (mainIdx + 1) % FRAMES.length;
        state.timer = window.setTimeout(tick, delay);
        return;
      }

      // 'pausing' or 'resuming' — both play through TRANSITION_FRAMES
      if (transIdx < TRANSITION_FRAMES.length) {
        renderFrame(TRANSITION_FRAMES[transIdx]);
        transIdx += 1;
        state.timer = window.setTimeout(tick, SPINNER_DELAY);
        return;
      }

      if (mode === 'pausing') {
        mode = 'paused';
        renderFrame('FAVICON');
      } else {
        mode = 'main';
        mainIdx = 0;
        tick();
      }
    };

    const updatePause = () => {
      const shouldPause = window.scrollY > SCROLL_PAUSE_THRESHOLD;
      if (shouldPause && (mode === 'main' || mode === 'resuming')) {
        if (state.timer !== null) clearTimeout(state.timer);
        mode = 'pausing';
        transIdx = 0;
        tick();
      } else if (!shouldPause && (mode === 'paused' || mode === 'pausing')) {
        if (state.timer !== null) clearTimeout(state.timer);
        mode = 'resuming';
        transIdx = 0;
        tick();
      }
    };

    state.scrollHandler = updatePause;
    window.addEventListener('scroll', updatePause, { passive: true });
    tick();
  };

  // Run on first load and after every SPA navigation
  setup();
  document.addEventListener('astro:page-load', setup);
  document.addEventListener('astro:before-swap', teardown);
</script>
