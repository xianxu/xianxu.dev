---
import { Icon } from 'astro-icon/components';

import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';
import SocialShare from '~/components/common/SocialShare.astro';
import Comments from '~/components/blog/Comments.astro';

import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

import 'katex/dist/katex.min.css';

import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;
---

<section class="py-8 sm:py-16 lg:py-20 mx-auto">
  <article>
    <header
      class={post.image
        ? 'intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade'
        : 'intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade'}
    >
      <div class="flex justify-between flex-col sm:flex-row max-w-3xl mx-auto mt-0 mb-2 px-4 sm:px-6 sm:items-center">
        <p>
          <Icon name="tabler:clock" class="w-4 h-4 inline-block -mt-0.5 dark:text-gray-400" />
          <time datetime={String(post.publishDate)} class="inline-block">{getFormattedDate(post.publishDate)}</time>
          {
            post.author && (
              <>
                {' '}
                · <Icon name="tabler:user" class="w-4 h-4 inline-block -mt-0.5 dark:text-gray-400" />
                <span class="inline-block">{post.author}</span>
              </>
            )
          }
          {
            post.category && (
              <>
                {' '}
                ·{' '}
                <a class="hover:underline inline-block" href={getPermalink(post.category.slug, 'category')}>
                  {post.category.title}
                </a>
              </>
            )
          }
          {
            post.readingTime && (
              <>
                &nbsp;· <span>{post.readingTime}</span> min read
              </>
            )
          }
        </p>
      </div>

      <h1
        class="px-4 sm:px-6 max-w-3xl mx-auto text-3xl md:text-4xl font-bold leading-tighter tracking-tighter font-heading"
      >
        {post.title}
      </h1>
      <p
        class="max-w-3xl mx-auto mt-4 mb-8 px-4 sm:px-6 text-lg md:text-xl text-muted dark:text-slate-400 sm:text-justify"
      >
        {post.excerpt}
      </p>

      {
        post.image ? (
          <Image
            src={post.image}
            class="max-w-full lg:max-w-[900px] mx-auto mb-6 sm:rounded-md bg-gray-400 dark:bg-slate-700"
            widths={[400, 900]}
            sizes="(max-width: 900px) 400px, 900px"
            alt={post?.excerpt || ''}
            width={900}
            height={506}
            loading="eager"
            decoding="async"
          />
        ) : (
          <div class="max-w-3xl mx-auto px-4 sm:px-6">
            <div class="border-t dark:border-slate-700" />
          </div>
        )
      }
    </header>
    <div
      class="mx-auto px-6 sm:px-6 max-w-3xl prose prose-lg md:prose-xl dark:prose-invert dark:prose-headings:text-slate-300 prose-headings:font-heading prose-headings:leading-tighter prose-headings:tracking-tighter prose-headings:font-bold prose-a:text-primary dark:prose-a:text-blue-400 prose-img:rounded-md prose-img:shadow-lg mt-8 prose-headings:scroll-mt-[80px] prose-li:my-0"
    >
      <slot />
    </div>
    <div class="mx-auto px-6 sm:px-6 max-w-3xl mt-8 flex justify-between flex-col sm:flex-row">
      <PostTags tags={post.tags} class="mr-5 rtl:mr-0 rtl:ml-5" />
      <SocialShare url={url} text={post.title} class="mt-5 sm:mt-1 align-middle text-gray-500 dark:text-slate-600" />
    </div>
    {post.comments !== false && <Comments />}
  </article>
</section>

<style is:global>
  /* Footnotes render subdued — smaller and muted vs. the body copy,
     with an auto separator and an auto-revealed "Footnotes" heading
     (GFM emits it sr-only; no need to hand-write a heading per post). */
  .prose .footnotes {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgb(203 213 225 / 0.7); /* slate-300 */
    font-size: 0.8rem;
    line-height: 1.55;
    color: rgb(100 116 139); /* slate-500 */
  }
  .dark .prose .footnotes {
    border-top-color: rgb(51 65 85 / 0.7); /* slate-700 */
    color: rgb(148 163 184); /* slate-400 */
  }
  /* Un-hide the screen-reader-only GFM heading, styled to match the subdued look */
  .prose .footnotes #footnote-label {
    position: static;
    width: auto;
    height: auto;
    margin: 0 0 0.6rem;
    padding: 0;
    overflow: visible;
    clip: auto;
    clip-path: none;
    white-space: normal;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: inherit;
  }
  .prose .footnotes p {
    margin-block: 0.4rem;
  }
  .prose .footnotes a {
    color: inherit;
    text-underline-offset: 2px;
  }
  .prose .footnotes a.data-footnote-backref {
    text-decoration: none;
  }
  /* KaTeX display math: scroll horizontally instead of overflowing the
     viewport on mobile (math can't auto-wrap mid-expression). */
  .prose .katex-display {
    max-width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    padding-block: 0.5rem; /* room so the scrollbar doesn't clip descenders */
  }
  @media (max-width: 640px) {
    .prose .katex-display > .katex {
      font-size: 0.9em; /* a touch smaller on phones, fewer equations need scrolling */
    }
  }
</style>
