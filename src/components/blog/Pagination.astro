---
import { Icon } from 'astro-icon/components';
import { getPermalink } from '~/utils/permalinks';
import { BLOG_BASE } from '~/utils/permalinks';

export interface Props {
  prevUrl?: string;
  nextUrl?: string;
  prevText?: string;
  nextText?: string;
  currentPage?: number;
  lastPage?: number;
}

const {
  prevUrl,
  nextUrl,
  prevText = 'Newer',
  nextText = 'Older',
  currentPage = 1,
  lastPage = 1,
} = Astro.props;

const pageHref = (n: number) => (n === 1 ? `/${BLOG_BASE}` : `/${BLOG_BASE}/${n}`);

// Compact list of page numbers with ellipses around the current page.
const buildPages = (current: number, last: number): Array<number | '…'> => {
  if (last <= 7) return Array.from({ length: last }, (_, i) => i + 1);
  const set = new Set<number>([1, last, current, current - 1, current + 1]);
  const sorted = [...set].filter((n) => n >= 1 && n <= last).sort((a, b) => a - b);
  const out: Array<number | '…'> = [];
  for (let i = 0; i < sorted.length; i++) {
    if (i > 0 && sorted[i] - sorted[i - 1] > 1) out.push('…');
    out.push(sorted[i]);
  }
  return out;
};

const pages = lastPage > 1 ? buildPages(currentPage, lastPage) : [];
---

{
  (prevUrl || nextUrl || pages.length > 0) && (
    <nav class="mt-12 flex items-center justify-center gap-1 text-sm" aria-label="Pagination">
      <a
        href={prevUrl ? getPermalink(prevUrl) : undefined}
        class:list={[
          'inline-flex items-center px-3 py-2 rounded hover:bg-gray-100 dark:hover:bg-slate-800 transition',
          { 'pointer-events-none opacity-30': !prevUrl },
        ]}
        aria-label={prevText}
        aria-disabled={!prevUrl}
      >
        <Icon name="tabler:chevron-left" class="w-4 h-4" />
        <span class="ml-1 hidden sm:inline">{prevText}</span>
      </a>

      {pages.map((p) =>
        p === '…' ? (
          <span class="px-2 text-muted">…</span>
        ) : p === currentPage ? (
          <span class="px-3 py-2 rounded bg-gray-100 dark:bg-slate-700 font-semibold">{p}</span>
        ) : (
          <a
            href={pageHref(p)}
            class="px-3 py-2 rounded hover:bg-gray-100 dark:hover:bg-slate-800 transition"
          >
            {p}
          </a>
        )
      )}

      <a
        href={nextUrl ? getPermalink(nextUrl) : undefined}
        class:list={[
          'inline-flex items-center px-3 py-2 rounded hover:bg-gray-100 dark:hover:bg-slate-800 transition',
          { 'pointer-events-none opacity-30': !nextUrl },
        ]}
        aria-label={nextText}
        aria-disabled={!nextUrl}
      >
        <span class="mr-1 hidden sm:inline">{nextText}</span>
        <Icon name="tabler:chevron-right" class="w-4 h-4" />
      </a>
    </nav>
  )
}
